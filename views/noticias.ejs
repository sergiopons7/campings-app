<!DOCTYPE html>
<html>
<head>
    <title>Noticias</title>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            display: flex;
            background: #f5f7fa;
        }

        .sidebar {
            width: 180px;
            height: 100vh;
            background: #1f2d3d;
            color: white;
            padding: 20px;
            position: fixed;
        }

        .sidebar a {
            display: block;
            padding: 10px;
            color: white;
            text-decoration: none;
        }

        .content {
            margin-left: 220px;
            width: 100%;
            padding: 30px;
        }

        .btn-add {
            background: #27ae60;
            color: white;
            padding: 10px;
            text-decoration: none;
            border-radius: 5px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 300px));
            gap: 20px;
            justify-content: center;
        }

        .card {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .card img {
            width: 100%;
            height: 140px;
            object-fit: cover;
        }

        .info {
            padding: 10px;
        }

        .btn {
            display: block;
            margin-top: 10px;
            background: #27ae60;
            color: white;
            padding: 8px;
            text-align: center;
            text-decoration: none;
        }
    </style>
</head>

<body>

<div class="sidebar">
    <h2>🏕 App</h2>
    <a href="/">Campings</a>
    <a href="/noticias">Noticias</a>
</div>

<div class="content">

    <h1>📰 Noticias</h1>

    <div style="margin-bottom:20px; text-align:right;">
        <a href="/nueva-noticia" class="btn-add">➕ Añadir noticia</a>
    </div>

    <div class="grid">

    <% if (noticias.length === 0) { %>
        <p>No hay noticias aún</p>
    <% } %>

    <% noticias.forEach(noticia => { %>
        <div class="card">

            <img src="<%= noticia.imagen %>">

            <div class="info">
                <h2><%= noticia.titulo %></h2>
                <p><%= noticia.descripcion %></p>

                <a href="<%= noticia.link %>" target="_blank" class="btn">
                    Leer más
                </a>
            </div>

        </div>
    <% }) %>

    </div>

</div>

</body>
</html>
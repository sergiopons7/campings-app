<!DOCTYPE html>
<html>
<head>
    <title>Encuentra tu Camping ideal</title>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            display: flex;
            background: #f5f7fa;
            color: #222;
        }

        /* SIDEBAR */
        .sidebar {
            width: 160px;
            height: 100vh;
            background: #1f2d3d;
            color: white;
            padding: 15px;
            position: fixed;
            top: 0;
            left: 0;
        }

        .sidebar h2 {
            font-size: 18px;
        }

        .sidebar a {
            display: block;
            padding: 8px;
            margin: 8px 0;
            color: white;
            text-decoration: none;
            border-radius: 6px;
            font-size: 14px;
        }

        .sidebar a:hover {
            background: #34495e;
        }

        /* CONTENIDO */
        .content {
            margin-left: 160px;
            width: 100%;
        }

        header {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            padding: 20px;
            text-align: center;
            color: white;
        }

        /* GRID DE TARJETAS */
        .container {
            display: grid;
            grid-template-columns: repeat(auto-fit, 250px);
            justify-content: center;
            gap: 25px;
            padding: 30px;
        }

        /* TARJETA */
        .card {
            background: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 5px 12px rgba(0,0,0,0.1);
            width: 250px;
            height: 300px;

            display: flex;
            flex-direction: column;
            justify-content: space-between;

            transition: all 0.25s ease;
            cursor: pointer;
        }

        /* HOVER */
        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.2);
        }

        /* IMAGEN */
        .card img {
            width: 100%;
            height: 140px;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .card:hover img {
            transform: scale(1.05);
        }

        /* INFO */
        .info {
            padding: 10px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .info h2 {
            font-size: 16px;
            margin-bottom: 5px;
            color: #222;
        }

        .info p {
            font-size: 13px;
            color: #555;
        }

        /* BOTÓN */
        .btn {
            margin-top: auto;
            padding: 8px;
            background: #27ae60;
            color: white;
            text-align: center;
            border-radius: 6px;
            text-decoration: none;
        }
    </style>
</head>

<body>

<div class="sidebar">
    <h2>🏕 </h2>

    <a href="/">🏕 Principal</a>
    <a href="/listado">📋 Listado</a>
    <a href="/mapa">🗺 Mapa</a>
    <a href="/noticias">📰 Noticias</a>
</div>

<div class="content">

<header>
    <h1>Busca tu camping ideal</h1>
</header>

<div class="container">

<% campings.forEach(camping => { %>
    <div class="card">
        <img src="<%= camping.imagen %>">

        <div class="info">
            <h2><%= camping.nombre %></h2>
            <p>📍 <%= camping.ubicacion %></p>

            <a href="/campings/<%= camping.id %>" class="btn">Ver más</a>
        </div>
    </div>
<% }) %>

</div>

</div>

</body>
</html>
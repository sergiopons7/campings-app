<!DOCTYPE html>
<html>
<head>
    <title>Encuentra tu Camping ideal</title>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            display: flex;
            background: #f5f7fa;
        }

        /* SIDEBAR */
        .sidebar {
            width: 220px;
            height: 100vh;
            background: #1f2d3d;
            color: white;
            padding: 20px;
            position: fixed;
        }

        .sidebar h2 {
            text-align: center;
        }

        .sidebar a {
            display: block;
            padding: 10px;
            margin: 8px 0;
            color: white;
            text-decoration: none;
            border-radius: 6px;
        }

        .sidebar a:hover {
            background: #34495e;
        }

        /* CONTENIDO */
        .content {
            margin-left: 220px;
            width: 100%;
        }

        header {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            padding: 20px;
            text-align: center;
            color: white;
        }

        .btn-add {
            display: inline-block;
            margin-top: 10px;
            padding: 8px 14px;
            background: white;
            color: #27ae60;
            border-radius: 6px;
            text-decoration: none;
            font-weight: bold;
        }

        /* GRID */
        .container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 250px));
            justify-content: center;
            gap: 20px;
            padding: 30px;
        }

        /* CARD */
        .card {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 12px rgba(0, 0, 0, 0.1);
        }

        img {
            width: 100%;
            height: 140px;
            object-fit: cover;
        }

        .info {
            padding: 10px;
        }

        h2 {
            font-size: 16px;
            margin-bottom: 5px;
        }

        p {
            font-size: 13px;
            color: #555;
        }

        .btn {
            display: block;
            margin-top: 10px;
            padding: 8px;
            background: #27ae60;
            color: white;
            text-align: center;
            border-radius: 5px;
            text-decoration: none;
        }

    </style>
</head>

<body>

<div class="sidebar">
    <h2>🏕 Menú</h2>

    <a href="/">🏕 Principal</a>
    <a href="/foro">💬 Foro</a>
    <a href="/noticias">📰 Noticias</a>
    <a href="/listado">📋 Listado</a>
</div>

<div class="content">

<header>
    <h1>Busca tu camping ideal </h1>
</header>

<div class="container">

<% campings.forEach(camping => { %>
    <div class="card">
        <img src="<%= camping.imagen %>">

        <div class="info">
            <h2><%= camping.nombre %></h2>
            <p>📍 <%= camping.ubicacion %></p>
            <p><%= camping.descripcion %></p>

            <a href="/campings/<%= camping.id %>" class="btn">Ver más</a>
        </div>
    </div>
<% }) %>

</div>

</div>

</body>
</html>
